func (i *SpeakersListPartialInput) CardVariant(s SpeakerItem) LiveSpeakerCardVariant {
	switch {
	case s.IsSpeaking:
		return LiveSpeakerCardSpeaking
	case s.IsWaiting:
		return LiveSpeakerCardWaiting
	default:
		return LiveSpeakerCardDone
	}
}

func (i *SpeakersListPartialInput) asLiveSpeakerContext() AttendeeSpeakersListPartialInput {
	return AttendeeSpeakersListPartialInput{
		Speakers: i.Speakers,
	}
}

func (i *SpeakersListPartialInput) ActionsForSpeaker(ctx context.Context, s SpeakerItem) []LiveSpeakerAction {
	if s.Status == "DONE" {
		return nil
	}

	if s.IsSpeaking {
		return []LiveSpeakerAction{
			{
				PostURL: i.SpeakerEndPostStr(ctx, &s),
				Target:  "#speakers-list-container",
				Swap:    "outerHTML",
				Title:   "End",
				Icon:    IconCheckCircle,
			},
		}
	}

	if s.IsWaiting {
		priorityIcon := IconStarOutline
		priorityTitle := "Give Priority"
		if s.Priority {
			priorityIcon = IconStar
			priorityTitle = "Remove Priority"
		}
		return []LiveSpeakerAction{
			{
				PostURL: i.SpeakerTogglePriorityPostStr(ctx, &s),
				Target:  "#speakers-list-container",
				Swap:    "outerHTML",
				Title:   priorityTitle,
				Icon:    priorityIcon,
			},
			{
				PostURL: i.SpeakerStartPostStr(ctx, &s),
				Target:  "#speakers-list-container",
				Swap:    "outerHTML",
				Title:   "Start",
				Icon:    IconArrowForward,
			},
			{
				PostURL: i.SpeakerRemovePostStr(ctx, &s),
				Target:  "#speakers-list-container",
				Swap:    "outerHTML",
				Title:   "Remove",
				Icon:    IconDelete,
				Confirm: "Remove this speaker?",
				Danger:  true,
			},
		}
	}

	return nil
}

func (i *SpeakersListPartialInput) CurrentSpeaker() *SpeakerItem {
	for idx := range i.Speakers {
		if i.Speakers[idx].IsSpeaking {
			return &i.Speakers[idx]
		}
	}
	return nil
}

func (i *SpeakersListPartialInput) NextWaitingSpeaker() *SpeakerItem {
	var next *SpeakerItem
	for idx := range i.Speakers {
		if !i.Speakers[idx].IsWaiting {
			continue
		}
		if next == nil || i.Speakers[idx].OrderPosition < next.OrderPosition {
			next = &i.Speakers[idx]
		}
	}
	return next
}

func (i *SpeakersListPartialInput) InitialScrollSpeaker() *SpeakerItem {
	if current := i.CurrentSpeaker(); current != nil {
		return current
	}
	return i.NextWaitingSpeaker()
}

func (i *SpeakersListPartialInput) IsInitialScrollSpeaker(s SpeakerItem) bool {
	initial := i.InitialScrollSpeaker()
	return initial != nil && initial.ID == s.ID
}

func (i *SpeakersListPartialInput) hasAttendeeWaitingType(attendeeID int64, speakerType string) bool {
	for _, s := range i.Speakers {
		if s.AttendeeID == attendeeID && s.IsWaiting && s.Type == speakerType {
			return true
		}
	}
	return false
}

type speakerCandidateSearchMatch struct {
	Attendee     AttendeeItem
	Score        int
	OriginalIndex int
}

func (i *SpeakersListPartialInput) FilteredSpeakerCandidates() []AttendeeItem {
	q := strings.TrimSpace(strings.ToLower(i.SearchQuery))
	if q == "" {
		result := make([]AttendeeItem, 0, len(i.Attendees))
		result = append(result, i.Attendees...)
		return result
	}

	numericQuery := isNumericSearchQuery(q)
	matches := make([]speakerCandidateSearchMatch, 0, len(i.Attendees))
	for idx, a := range i.Attendees {
		score := 0
		var ok bool
		if numericQuery {
			score, ok = numericSearchScore(strconv.FormatInt(a.AttendeeNumber, 10), q)
		} else {
			score, ok = textSearchScore(strings.ToLower(a.FullName), q)
		}
		if !ok {
			continue
		}
		matches = append(matches, speakerCandidateSearchMatch{
			Attendee:      a,
			Score:         score,
			OriginalIndex: idx,
		})
	}

	sort.SliceStable(matches, func(a, b int) bool {
		if matches[a].Score != matches[b].Score {
			return matches[a].Score > matches[b].Score
		}

		numA := matches[a].Attendee.AttendeeNumber
		numB := matches[b].Attendee.AttendeeNumber
		if numA != numB {
			return numA < numB
		}

		nameA := strings.ToLower(matches[a].Attendee.FullName)
		nameB := strings.ToLower(matches[b].Attendee.FullName)
		if nameA != nameB {
			return nameA < nameB
		}

		return matches[a].OriginalIndex < matches[b].OriginalIndex
	})

	result := make([]AttendeeItem, 0, len(i.Attendees))
	for _, match := range matches {
		result = append(result, match.Attendee)
	}
	return result
}

func isNumericSearchQuery(q string) bool {
	if q == "" {
		return false
	}
	for _, r := range q {
		if !unicode.IsDigit(r) {
			return false
		}
	}
	return true
}

func numericSearchScore(candidateNumber, q string) (int, bool) {
	if candidateNumber == q {
		return 5000, true
	}

	if strings.HasPrefix(candidateNumber, q) {
		return 4000 - len(candidateNumber), true
	}

	idx := strings.Index(candidateNumber, q)
	if idx < 0 {
		return 0, false
	}

	return 3000 - (idx * 8) - len(candidateNumber), true
}

func textSearchScore(candidateName, q string) (int, bool) {
	best := 0

	if candidateName == q {
		best = 6000
	}

	if strings.HasPrefix(candidateName, q) {
		score := 5200 - len(candidateName)
		if score > best {
			best = score
		}
	}

	for _, token := range strings.Fields(candidateName) {
		if strings.HasPrefix(token, q) {
			score := 5000 - len(token)
			if score > best {
				best = score
			}
		}
	}

	if idx := strings.Index(candidateName, q); idx >= 0 {
		score := 4200 - (idx * 8)
		if score > best {
			best = score
		}
	}

	if fuzzy, ok := fuzzySubsequenceScore(candidateName, q); ok && fuzzy > best {
		best = fuzzy
	}

	if best <= 0 {
		return 0, false
	}
	return best, true
}

func fuzzySubsequenceScore(candidate, q string) (int, bool) {
	candidateRunes := []rune(candidate)
	queryRunes := []rune(q)
	if len(queryRunes) == 0 {
		return 0, false
	}

	queryIdx := 0
	firstMatch := -1
	prevMatch := -1
	gapPenalty := 0

	for idx, r := range candidateRunes {
		if queryIdx >= len(queryRunes) {
			break
		}
		if r != queryRunes[queryIdx] {
			continue
		}
		if firstMatch == -1 {
			firstMatch = idx
		}
		if prevMatch >= 0 {
			gapPenalty += idx - prevMatch - 1
		}
		prevMatch = idx
		queryIdx++
	}

	if queryIdx != len(queryRunes) {
		return 0, false
	}

	score := 2600 - (firstMatch * 10) - (gapPenalty * 6) - (len(candidateRunes) - len(queryRunes))
	if score < 1 {
		score = 1
	}
	return score, true
}

type MeetingManageInput struct {
	CommitteeName          string
	CommitteeSlug          string
	MeetingName            string
	MeetingID              int64
	IDString               string
	Attendees              []AttendeeItem
	SignupOpen             bool
	// Meeting-level quotation settings
	GenderQuotationEnabled          bool
	FirstSpeakerQuotationEnabled    bool
	ModeratorID                     *int64
	AgendaPoints                    []AgendaPointItem
	CurrentAgendaPointID            *int64
	// Active agenda point settings (if any AP is active)
	AgendaPointIDString             string
	AgendaPointGenderQuotation      *bool
	AgendaPointFirstSpeakerQuotation *bool
	AgendaPointModeratorID          *int64
	// Resolved effective settings for the active AP
	EffectiveGenderQuotation        bool
	EffectiveFirstSpeakerQuotation  bool
	Speakers                        []SpeakerItem
	Error                           string
}

