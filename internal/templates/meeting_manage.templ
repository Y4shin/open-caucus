templ AgendaPointListPartial(input AgendaPointListPartialInput) {
	<div id="agenda-point-list-container">
		if input.Error != "" {
			<p class={ ErrorText() }>{ input.Error }</p>
		}
		<h3>Add Agenda Point</h3>
		<form
			hx-post={ input.AgendaPointCreatePostStr(ctx) }
			hx-target="#agenda-point-list-container"
			hx-swap="outerHTML"
			hx-on::after-request="if(event.detail.successful) this.reset()"
		>
			<div>
				<label for="ap_title">Title:</label>
				<input type="text" id="ap_title" name="title" required/>
			</div>
			<div>
				<label for="ap_parent_id">Parent (optional):</label>
				<select id="ap_parent_id" name="parent_id">
					<option value="">-- top-level --</option>
					for _, p := range input.ParentOptions {
						<option value={ p.IDString }>{ p.Title }</option>
					}
				</select>
			</div>
			<button type="submit">Add Agenda Point</button>
		</form>
		if len(input.AgendaPoints) == 0 {
			<p>No agenda points yet.</p>
		} else {
			<table class={ DataTable() }>
				<thead>
					<tr>
						<th>#</th>
						<th>Title</th>
						<th>Active</th>
						<th>Actions</th>
					</tr>
				</thead>
				<tbody>
					for _, ap := range input.AgendaPoints {
						<tr>
							<td>{ strconv.FormatInt(ap.Position, 10) }</td>
							<td>
								if ap.ParentID != nil {
									-> { ap.Title }
								} else {
									{ ap.Title }
								}
							</td>
							<td>
								if ap.IsActive {
									Yes
								} else {
									No
								}
							</td>
							<td>
								if !ap.IsActive {
									<form
										hx-post={ input.AgendaPointActivatePostStr(ctx, &ap) }
										hx-target="#agenda-point-list-container"
										hx-swap="outerHTML"
										class={ InlineForm() }
									>
										<button type="submit">Activate</button>
									</form>
								}
								<form
									hx-post={ input.AgendaPointDeletePostStr(ctx, &ap) }
									hx-target="#agenda-point-list-container"
									hx-swap="outerHTML"
									hx-confirm="Delete this agenda point?"
									class={ InlineForm() }
								>
									<button type="submit">Delete</button>
								</form>
								<a href={ input.AgendaPointToolsGet(ctx, &ap) }>
									<button type="button">Open Tools</button>
								</a>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}
	</div>
}

templ SpeakersListPartial(input SpeakersListPartialInput) {
	<div
		id="speakers-list-container"
		sse-swap="manage-speakers-list-updated"
		hx-swap="outerHTML"
		hx-swap-oob="true"
	>
		if input.Error != "" {
			<p class={ ErrorText() }>{ input.Error }</p>
		}
		if input.CurrentAgendaPointID == nil {
			<p>No active agenda point. Activate one above to manage the speakers list.</p>
		} else {
			<h3>Quotation Settings</h3>
			<form
				hx-post={ input.AgendaPointQuotationPostStr(ctx) }
				hx-target="#speakers-list-container"
				hx-swap="outerHTML"
			>
				<div>
					<label for="ap_gender_quotation">Gender quotation:</label>
					<select id="ap_gender_quotation" name="gender_quotation_enabled">
						<option value="" selected?={ input.AgendaPointGenderQuotation == nil }>Inherit from meeting</option>
						<option value="true" selected?={ input.AgendaPointGenderQuotation != nil && *input.AgendaPointGenderQuotation }>Enabled</option>
						<option value="false" selected?={ input.AgendaPointGenderQuotation != nil && !*input.AgendaPointGenderQuotation }>Disabled</option>
					</select>
				</div>
				<div>
					<label for="ap_first_speaker">First-speaker bonus:</label>
					<select id="ap_first_speaker" name="first_speaker_quotation_enabled">
						<option value="" selected?={ input.AgendaPointFirstSpeakerQuotation == nil }>Inherit from meeting</option>
						<option value="true" selected?={ input.AgendaPointFirstSpeakerQuotation != nil && *input.AgendaPointFirstSpeakerQuotation }>Enabled</option>
						<option value="false" selected?={ input.AgendaPointFirstSpeakerQuotation != nil && !*input.AgendaPointFirstSpeakerQuotation }>Disabled</option>
					</select>
				</div>
				<button type="submit">Apply</button>
			</form>
			<p>
				Effective: gender quotation
				if input.EffectiveGenderQuotation {
					<strong>on</strong>
				} else {
					<strong>off</strong>
				}
				, first-speaker bonus
				if input.EffectiveFirstSpeakerQuotation {
					<strong>on</strong>
				} else {
					<strong>off</strong>
				}
			</p>
			<h3>Agenda Point Moderator</h3>
			<form
				hx-post={ input.AgendaPointModeratorPostStr(ctx) }
				hx-target="#speakers-list-container"
				hx-swap="outerHTML"
			>
				<select name="attendee_id">
					<option value="" selected?={ input.ModeratorID == nil }>-- none --</option>
					for _, a := range input.Attendees {
						<option value={ a.IDString } selected?={ input.ModeratorID != nil && *input.ModeratorID == a.ID }>{ a.FullName }</option>
					}
				</select>
				<button type="submit">Set Moderator</button>
			</form>
			<h3>Add Speaker</h3>
			<form
				hx-post={ input.SpeakerAddPostStr(ctx) }
				hx-target="#speakers-list-container"
				hx-swap="outerHTML"
				hx-on::after-request="if(event.detail.successful) this.reset()"
			>
				<div>
					<label for="speaker_attendee_id">Attendee:</label>
					<select id="speaker_attendee_id" name="attendee_id" required>
						<option value="">-- select --</option>
						for _, a := range input.Attendees {
							<option value={ a.IDString }>{ a.FullName }</option>
						}
					</select>
				</div>
				<div>
					<label for="speaker_type">Type:</label>
					<select id="speaker_type" name="type" required>
						<option value="regular">Regular</option>
						<option value="ropm">RoPM</option>
					</select>
				</div>
				<button type="submit">Add Speaker</button>
			</form>
			if len(input.Speakers) == 0 {
				<p>No speakers in the queue.</p>
			} else {
				<table class={ DataTable() }>
					<thead>
						<tr>
							<th>Name</th>
							<th>Type</th>
							<th>Status</th>
							<th>Q</th>
							<th>1st</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						for _, s := range input.Speakers {
							<tr>
								<td>{ s.AttendeeName }</td>
								<td>{ s.Type }</td>
								<td>{ s.Status }</td>
								<td>
									if s.GenderQuoted {
										Q
									}
								</td>
								<td>
									if s.FirstSpeaker {
										1st
									}
								</td>
								<td>
									if s.IsWaiting {
										<form
											hx-post={ input.SpeakerTogglePriorityPostStr(ctx, &s) }
											hx-target="#speakers-list-container"
											hx-swap="outerHTML"
											class={ InlineForm() }
										>
											if s.Priority {
												<button type="submit" title="Remove priority">★</button>
											} else {
												<button type="submit" title="Give priority">☆</button>
											}
										</form>
									}
									if s.IsWaiting {
										<form
											hx-post={ input.SpeakerStartPostStr(ctx, &s) }
											hx-target="#speakers-list-container"
											hx-swap="outerHTML"
											class={ InlineForm() }
										>
											<button type="submit">Start</button>
										</form>
									}
									if s.IsSpeaking {
										<form
											hx-post={ input.SpeakerEndPostStr(ctx, &s) }
											hx-target="#speakers-list-container"
											hx-swap="outerHTML"
											class={ InlineForm() }
										>
											<button type="submit">End</button>
										</form>
									}
									if s.IsWaiting {
										<form
											hx-post={ input.SpeakerWithdrawPostStr(ctx, &s) }
											hx-target="#speakers-list-container"
											hx-swap="outerHTML"
											class={ InlineForm() }
										>
											<button type="submit">Withdraw</button>
										</form>
									}
									<form
										hx-post={ input.SpeakerRemovePostStr(ctx, &s) }
										hx-target="#speakers-list-container"
										hx-swap="outerHTML"
										hx-confirm="Remove this speaker?"
										class={ InlineForm() }
									>
										<button type="submit">Remove</button>
									</form>
								</td>
							</tr>
						}
					</tbody>
				</table>
			}
		}
	</div>
}

