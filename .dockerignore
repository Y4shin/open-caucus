# Version control
.git
.gitignore
.gitattributes

# Nix / direnv
.direnv
flake.nix
flake.lock
.envrc

# IDE / editor
.vscode
.idea
*.swp
*.swo
.DS_Store

# CI / Docker meta
.github
docker-compose*.yml

# AI tooling
.claude
CLAUDE.md
AGENTS.md
.mcp.json

# Documentation scratch area — not compiled into the binary
docs-rewrite/
README.md
# doc/ is intentionally NOT excluded: doc/embed.go embeds content/ and assets/
# into the binary and must be present in the build context.

# Dev-only tooling
# tools/docscapture/ is intentionally NOT excluded: it is imported by cmd/docs_capture.go.
# tools/vote-fuzzer/ is a standalone dev tool with no imports from cmd/, safe to exclude.
.air.vite.toml
Taskfile.yaml
tools/vote-fuzzer/

# Environment files — never bake secrets into the image
.env
.env.local
.env.*.local

# Dev OIDC provider data
dev/

# User uploads — runtime data, not build-time
uploads/

# E2E tests
e2e/

# Compiled / local build artifacts
tmp/
conference-tool
conference-tool.exe
web/node_modules
web/.svelte-kit
web/build
node_modules

# Generated code (regenerated inside Docker build)
**/*_generated.go
**/*_gen.go
**/*_templ.go

# Test / coverage artifacts
coverage.out
coverage.html
*.test
*.log

# Database files — runtime data, not build-time
*.db
*.sqlite
*.sqlite3
