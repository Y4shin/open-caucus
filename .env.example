# ============================================================
# Application Configuration
# ============================================================

# Environment (development, staging, production) (Constraints: must be one of: development,staging,production)
ENVIRONMENT=development
# HTTP server bind address
HOST=0.0.0.0
# Log format (json, text) (Constraints: must be one of: json,text)
LOG_FORMAT=json
# Log level (debug, info, warn, error) (Constraints: must be one of: debug,info,warn,error)
LOG_LEVEL=info
# HTTP server port (Constraints: must be in range 1:65535)
PORT=8080
# Service name for identification
SERVICE_NAME=conference-tool
# ============================================================
# Session Management
# ============================================================

# Secret key for signing session cookies (must be 32+ chars)
SESSION_SECRET=change-this-to-a-random-32-character-string
# Session expiration in seconds
SESSION_EXPIRATION=86400
# ============================================================
# Authentication Providers
# ============================================================

# Enable password login provider
AUTH_PASSWORD_ENABLED=true
# Enable OAuth/OIDC login provider
AUTH_OAUTH_ENABLED=false
# OIDC issuer URL (required when OAuth is enabled)
OAUTH_ISSUER_URL=
# OIDC client ID (required when OAuth is enabled)
OAUTH_CLIENT_ID=
# OIDC client secret (required when OAuth is enabled)
OAUTH_CLIENT_SECRET=
# OAuth callback URL (required when OAuth is enabled)
OAUTH_REDIRECT_URL=
# OAuth scopes as comma-separated values
OAUTH_SCOPES=openid,profile,email
# JWT claim name used for group extraction
OAUTH_GROUPS_CLAIM=groups
# Fallback JWT claims for username, comma-separated
OAUTH_USERNAME_CLAIMS=preferred_username,email,sub
# Fallback JWT claims for full name, comma-separated
OAUTH_FULL_NAME_CLAIMS=name,preferred_username,email
# OAuth provisioning mode (preprovisioned, auto_create)
OAUTH_PROVISIONING_MODE=preprovisioned
# Optional required groups for OAuth provisioning, comma-separated
OAUTH_REQUIRED_GROUPS=
# Optional group that toggles local admin flag on each OAuth login
OAUTH_ADMIN_GROUP=ca-admin
# When set, only OIDC groups with this prefix can be used in committee group rules
OAUTH_COMMITTEE_GROUP_PREFIX=
# Max age for OAuth state cookie in seconds
OAUTH_STATE_TTL_SECONDS=300
# ============================================================
# Local OIDC Development Provider
# ============================================================

# Path to YAML file containing local OIDC users
OIDC_DEV_USERS_FILE=dev/users.yaml
# Claim name used to expose groups from local OIDC users
OIDC_DEV_GROUPS_CLAIM=groups
# Optional explicit listen address for local OIDC provider (host:port).
# Leave empty to derive host/port from OAUTH_ISSUER_URL.
OIDC_DEV_LISTEN_ADDR=
# ============================================================
# Outbound Webhooks
# ============================================================

# Comma-separated list of URLs to POST meeting events to.
# Leave unset or empty to disable webhooks entirely.
WEBHOOK_URLS=
# Shared secret sent as the X-Webhook-Secret header on every request.
WEBHOOK_SECRET=
# Per-request HTTP timeout in seconds (default: 10)
WEBHOOK_TIMEOUT_SECONDS=10
# ============================================================
# Email (SMTP)
# ============================================================

# Enable email sending (meeting invites)
EMAIL_ENABLED=false
# SMTP server hostname
EMAIL_SMTP_HOST=
# SMTP server port (587 for STARTTLS, 1025 for Mailpit dev)
EMAIL_SMTP_PORT=587
# SMTP authentication username (leave empty for unauthenticated)
EMAIL_USERNAME=
# SMTP authentication password
EMAIL_PASSWORD=
# Sender email address
EMAIL_FROM_ADDRESS=
# Sender display name
EMAIL_FROM_NAME=Open Caucus
# ============================================================
# Database Configuration
# ============================================================

# Path to the SQLite database file
DATABASE_PATH=conference.db
