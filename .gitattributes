# Normalize all text files to LF on commit; checkout uses LF everywhere.
* text=auto eol=lf

# Explicitly binary — never touch endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.db binary
